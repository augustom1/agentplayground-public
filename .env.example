# ─────────────────────────────────────────────────────────────────
# VPS Master Stack — Environment Variables Reference
# Copy to .env.local and fill in your values.
# Run setup.sh for an interactive guided setup.
# ─────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────
DOMAIN=mycompany.com
ACME_EMAIL=you@mycompany.com

# ── PostgreSQL (shared across all services) ───────────────────────
# All services use the same Postgres server, each with its own database.
# Dashboard → agent_dashboard db
# n8n       → n8n db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-something-strong
POSTGRES_DB=agent_dashboard

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-too

# ── Agent Dashboard ───────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=
NEXTAUTH_URL=https://app.mycompany.com
NEXT_PUBLIC_APP_URL=https://app.mycompany.com
# Generate: openssl rand -hex 32
CRON_SECRET=

# ── AI Provider ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── n8n ───────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_HOST=n8n.mycompany.com
N8N_PROTOCOL=https

# ── Open WebUI ────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
OPEN_WEBUI_SECRET=

# ── Port overrides (local dev only — not used in production) ───────
# DASHBOARD_PORT=3000
# N8N_PORT=5678
# OLLAMA_PORT=11434
# OPEN_WEBUI_PORT=8081
# NGINX_PORT=8082
# FILEBROWSER_PORT=8083
# PORTAINER_PORT=9000
