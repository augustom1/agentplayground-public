# ─── Auth (NextAuth) ──────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=generate-with-openssl-rand-hex-32

# ─── AI Provider ──────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Database ─────────────────────────────────
# Local dev (docker-compose.yml overrides this automatically):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_dashboard?schema=public

# ─── PostgreSQL (used by docker-compose) ──────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=agent_dashboard

# ─── Agent Service Base URL ───────────────────
# AGENTS_BASE_URL=http://localhost

# ─── Dashboard Port (local dev only) ──────────
DASHBOARD_PORT=3000

# ─── Production only (docker-compose.prod.yml) ──
# Your domain name (must point to your VPS IP before deploying)
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@yourdomain.com

# Secret for the /api/cron endpoint (generate with: openssl rand -hex 32)
CRON_SECRET=change-me-generate-a-random-secret
